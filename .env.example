# Notion internal integration token (starts with "ntn_" or "secret_").
# Create one at https://www.notion.so/my-integrations and share your
# top-level pages/teamspaces with the integration.
NOTION_TOKEN=

# Directory the backup tree is written to (relative paths are resolved from
# the current working directory). Defaults to ./backup when unset.
# Raw JSON goes in <BACKUP_DIR>/json; rendered Markdown/CSV in <BACKUP_DIR>/markdown.
BACKUP_DIR=backup

# Whether to render the JSON into Markdown pages + CSV database indexes.
# The raw JSON dump always runs; this controls the optional second stage.
# Accepts: true/false, 1/0, yes/no, on/off. Defaults to false (JSON only).
RENDER_MARKDOWN=false

# Force a full re-fetch every run instead of an incremental dump. When false
# (default), runs with an existing JSON tree only re-fetch objects whose
# last_edited_time changed. Set true to bypass the optimization.
FULL_SYNC=false

# Optional git remote to push to after committing. Leave empty to skip pushing.
GIT_REMOTE=

# Override the Notion-Version header. Defaults to 2025-09-03.
NOTION_API_VERSION=
